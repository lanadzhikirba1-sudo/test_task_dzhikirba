<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Task2_Publication" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.1">
  <bpmn:collaboration id="Collaboration_Task2">
    <bpmn:participant id="Participant_Task2" name="UC-1 Публикация товара на витрине (Task2_dzhikirba)" processRef="Process_Task2_Publication" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Task2_Publication" name="Публикация товара на витрине" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Task2">
      <bpmn:lane id="Lane_Seller" name="Продавец">
        <bpmn:flowNodeRef>Start_Task2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OpenCard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ClickPublish</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Success</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System" name="Система (ЛК / бэкенд)">
        <bpmn:flowNodeRef>Task_ShowPublishButton</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ValidateConditions</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ConditionsOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_A1_ShowValidationErrors</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PublishAndCatalog</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PublishResult</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_A2_ServiceError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LogHistoryAndResult</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Task2" name="Начало">
      <bpmn:outgoing>Flow_to_OpenCard</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_OpenCard" name="Открыть карточку товара или список в ЛК">
      <bpmn:incoming>Flow_to_OpenCard</bpmn:incoming>
      <bpmn:outgoing>Flow_to_ShowPublish</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_ShowPublishButton" name="Отобразить действие «Опубликовать»">
      <bpmn:incoming>Flow_to_ShowPublish</bpmn:incoming>
      <bpmn:outgoing>Flow_to_ClickPublish</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_ClickPublish" name="Нажать «Опубликовать» и подтвердить">
      <bpmn:incoming>Flow_to_ClickPublish</bpmn:incoming>
      <bpmn:incoming>Flow_A1_Repeat</bpmn:incoming>
      <bpmn:incoming>Flow_A2_Repeat</bpmn:incoming>
      <bpmn:outgoing>Flow_to_Validate</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_ValidateConditions" name="Проверить обязательные условия публикации">
      <bpmn:incoming>Flow_to_Validate</bpmn:incoming>
      <bpmn:outgoing>Flow_to_GW_Conditions</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_ConditionsOk" name="Условия выполнены?">
      <bpmn:incoming>Flow_to_GW_Conditions</bpmn:incoming>
      <bpmn:outgoing>Flow_Conditions_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_Conditions_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_A1_ShowValidationErrors" name="A1: Сообщить, какие условия не выполнены (статус черновик)">
      <bpmn:incoming>Flow_Conditions_No</bpmn:incoming>
      <bpmn:outgoing>Flow_A1_Repeat</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_PublishAndCatalog" name="Перевести в «опубликован», витрина, уведомление в ЛК">
      <bpmn:incoming>Flow_Conditions_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_to_GW_PublishResult</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_PublishResult" name="Публикация завершилась успешно?">
      <bpmn:incoming>Flow_to_GW_PublishResult</bpmn:incoming>
      <bpmn:outgoing>Flow_Publish_Error</bpmn:outgoing>
      <bpmn:outgoing>Flow_Publish_Ok</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_A2_ServiceError" name="A2: Сообщение об ошибке сервиса (черновик, повтор позже)">
      <bpmn:incoming>Flow_Publish_Error</bpmn:incoming>
      <bpmn:outgoing>Flow_A2_Repeat</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_LogHistoryAndResult" name="Запись в историю операций, показать результат продавцу">
      <bpmn:incoming>Flow_Publish_Ok</bpmn:incoming>
      <bpmn:outgoing>Flow_to_EndSuccess</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_Success" name="Товар опубликован на витрине">
      <bpmn:incoming>Flow_to_EndSuccess</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_to_OpenCard" sourceRef="Start_Task2" targetRef="Task_OpenCard" />
    <bpmn:sequenceFlow id="Flow_to_ShowPublish" sourceRef="Task_OpenCard" targetRef="Task_ShowPublishButton" />
    <bpmn:sequenceFlow id="Flow_to_ClickPublish" sourceRef="Task_ShowPublishButton" targetRef="Task_ClickPublish" />
    <bpmn:sequenceFlow id="Flow_to_Validate" sourceRef="Task_ClickPublish" targetRef="Task_ValidateConditions" />
    <bpmn:sequenceFlow id="Flow_to_GW_Conditions" sourceRef="Task_ValidateConditions" targetRef="Gateway_ConditionsOk" />
    <bpmn:sequenceFlow id="Flow_Conditions_No" name="Нет" sourceRef="Gateway_ConditionsOk" targetRef="Task_A1_ShowValidationErrors" />
    <bpmn:sequenceFlow id="Flow_Conditions_Yes" name="Да" sourceRef="Gateway_ConditionsOk" targetRef="Task_PublishAndCatalog" />
    <bpmn:sequenceFlow id="Flow_A1_Repeat" name="A3: повторная попытка" sourceRef="Task_A1_ShowValidationErrors" targetRef="Task_ClickPublish" />
    <bpmn:sequenceFlow id="Flow_to_GW_PublishResult" sourceRef="Task_PublishAndCatalog" targetRef="Gateway_PublishResult" />
    <bpmn:sequenceFlow id="Flow_Publish_Error" name="Ошибка сервиса" sourceRef="Gateway_PublishResult" targetRef="Task_A2_ServiceError" />
    <bpmn:sequenceFlow id="Flow_Publish_Ok" name="Успех" sourceRef="Gateway_PublishResult" targetRef="Task_LogHistoryAndResult" />
    <bpmn:sequenceFlow id="Flow_A2_Repeat" name="A3: повторная попытка" sourceRef="Task_A2_ServiceError" targetRef="Task_ClickPublish" />
    <bpmn:sequenceFlow id="Flow_to_EndSuccess" sourceRef="Task_LogHistoryAndResult" targetRef="End_Success" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Task2">
    <bpmndi:BPMNPlane id="BPMNPlane_Task2" bpmnElement="Collaboration_Task2">
      <bpmndi:BPMNShape id="BPMNShape_Participant_Task2" bpmnElement="Participant_Task2" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1720" height="560" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_System_di" bpmnElement="Lane_System" isHorizontal="true">
        <dc:Bounds x="190" y="300" width="1690" height="340" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Seller_di" bpmnElement="Lane_Seller" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="1690" height="220" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_Task2_di" bpmnElement="Start_Task2">
        <dc:Bounds x="212" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="206" y="225" width="44" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_OpenCard_di" bpmnElement="Task_OpenCard">
        <dc:Bounds x="280" y="170" width="150" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ClickPublish_di" bpmnElement="Task_ClickPublish">
        <dc:Bounds x="480" y="170" width="160" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Success_di" bpmnElement="End_Success">
        <dc:Bounds x="1700" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1678" y="225" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ShowPublishButton_di" bpmnElement="Task_ShowPublishButton">
        <dc:Bounds x="360" y="370" width="150" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ValidateConditions_di" bpmnElement="Task_ValidateConditions">
        <dc:Bounds x="700" y="370" width="180" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ConditionsOk_di" bpmnElement="Gateway_ConditionsOk" isMarkerVisible="true">
        <dc:Bounds x="940" y="385" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="918" y="348" width="94" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_A1_ShowValidationErrors_di" bpmnElement="Task_A1_ShowValidationErrors">
        <dc:Bounds x="865" y="520" width="200" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PublishAndCatalog_di" bpmnElement="Task_PublishAndCatalog">
        <dc:Bounds x="1080" y="370" width="220" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PublishResult_di" bpmnElement="Gateway_PublishResult" isMarkerVisible="true">
        <dc:Bounds x="1350" y="385" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1318" y="348" width="114" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_A2_ServiceError_di" bpmnElement="Task_A2_ServiceError">
        <dc:Bounds x="1275" y="520" width="200" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_LogHistoryAndResult_di" bpmnElement="Task_LogHistoryAndResult">
        <dc:Bounds x="1470" y="370" width="200" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_to_OpenCard_di" bpmnElement="Flow_to_OpenCard">
        <di:waypoint x="248" y="200" />
        <di:waypoint x="280" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_ShowPublish_di" bpmnElement="Flow_to_ShowPublish">
        <di:waypoint x="430" y="210" />
        <di:waypoint x="430" y="330" />
        <di:waypoint x="435" y="330" />
        <di:waypoint x="435" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_ClickPublish_di" bpmnElement="Flow_to_ClickPublish">
        <di:waypoint x="510" y="410" />
        <di:waypoint x="560" y="410" />
        <di:waypoint x="560" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_Validate_di" bpmnElement="Flow_to_Validate">
        <di:waypoint x="640" y="210" />
        <di:waypoint x="790" y="210" />
        <di:waypoint x="790" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_GW_Conditions_di" bpmnElement="Flow_to_GW_Conditions">
        <di:waypoint x="880" y="410" />
        <di:waypoint x="940" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Conditions_No_di" bpmnElement="Flow_Conditions_No">
        <di:waypoint x="965" y="435" />
        <di:waypoint x="965" y="520" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="970" y="468" width="19" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Conditions_Yes_di" bpmnElement="Flow_Conditions_Yes">
        <di:waypoint x="990" y="410" />
        <di:waypoint x="1080" y="410" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1020" y="392" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A1_Repeat_di" bpmnElement="Flow_A1_Repeat">
        <di:waypoint x="865" y="560" />
        <di:waypoint x="200" y="560" />
        <di:waypoint x="200" y="210" />
        <di:waypoint x="480" y="210" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="220" y="365" width="120" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_GW_PublishResult_di" bpmnElement="Flow_to_GW_PublishResult">
        <di:waypoint x="1300" y="410" />
        <di:waypoint x="1350" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Publish_Error_di" bpmnElement="Flow_Publish_Error">
        <di:waypoint x="1375" y="435" />
        <di:waypoint x="1375" y="520" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1280" y="468" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Publish_Ok_di" bpmnElement="Flow_Publish_Ok">
        <di:waypoint x="1400" y="410" />
        <di:waypoint x="1470" y="410" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1418" y="392" width="34" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A2_Repeat_di" bpmnElement="Flow_A2_Repeat">
        <di:waypoint x="1275" y="560" />
        <di:waypoint x="200" y="560" />
        <di:waypoint x="200" y="210" />
        <di:waypoint x="480" y="210" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="220" y="575" width="120" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_EndSuccess_di" bpmnElement="Flow_to_EndSuccess">
        <di:waypoint x="1670" y="410" />
        <di:waypoint x="1718" y="410" />
        <di:waypoint x="1718" y="200" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
