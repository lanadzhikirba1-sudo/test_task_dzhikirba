<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Task2_Publication" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.1">
  <bpmn:collaboration id="Collaboration_Task2">
    <bpmn:participant id="Participant_Task2" name="UC-1 Публикация товара на витрине" processRef="Process_Task2_Publication" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Task2_Publication" name="Публикация товара на витрине" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Task2">
      <bpmn:lane id="Lane_System" name="Backend">
        <bpmn:flowNodeRef>Task_LogHistoryAndResult</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ConditionsOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PublishAndCatalog</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PublishResult</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_02wmdhm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_0d9badk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ValidateConditions</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Seller" name="Продавец - UI">
        <bpmn:flowNodeRef>Start_Task2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OpenCard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShowPublishButton</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_0ttedc3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ClickPublish</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_A2_ServiceError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0s9661u</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1earkek</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Success</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_0wuwlm4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_07wnm8t</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Task2" name="Начало">
      <bpmn:outgoing>Flow_to_OpenCard</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_OpenCard" name="Открыть товар в ЛК">
      <bpmn:incoming>Flow_to_OpenCard</bpmn:incoming>
      <bpmn:outgoing>Flow_to_ShowPublish</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_ShowPublishButton" name="Отобразить действие «Опубликовать»">
      <bpmn:incoming>Flow_160iz9a</bpmn:incoming>
      <bpmn:outgoing>Flow_to_ClickPublish</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_0ttedc3" name="Отобразить действие «Снять с публикации»">
      <bpmn:incoming>Flow_0sp9ed0</bpmn:incoming>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_LogHistoryAndResult" name="Запись в историю операций">
      <bpmn:incoming>Flow_02jimq0</bpmn:incoming>
      <bpmn:outgoing>Flow_to_EndSuccess</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_ClickPublish" name="Нажать «Опубликовать» и подтвердить">
      <bpmn:incoming>Flow_to_ClickPublish</bpmn:incoming>
      <bpmn:incoming>Flow_1r181wj</bpmn:incoming>
      <bpmn:outgoing>Flow_to_Validate</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_ConditionsOk" name="Обязательные условия для публикации выполнены?">
      <bpmn:incoming>Flow_1u0ne0m</bpmn:incoming>
      <bpmn:outgoing>Flow_Conditions_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_Conditions_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_PublishAndCatalog" name="Перевести в «опубликован»">
      <bpmn:incoming>Flow_Conditions_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_0irkyr6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_PublishResult" name="Публикация завершилась успешно?">
      <bpmn:incoming>Flow_0irkyr6</bpmn:incoming>
      <bpmn:outgoing>Flow_Publish_Error</bpmn:outgoing>
      <bpmn:outgoing>Flow_Publish_Ok</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:parallelGateway id="Gateway_02wmdhm">
      <bpmn:incoming>Flow_Publish_Ok</bpmn:incoming>
      <bpmn:outgoing>Flow_02jimq0</bpmn:outgoing>
      <bpmn:outgoing>Flow_1g98zh1</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:exclusiveGateway id="Gateway_0d9badk" name="Товар опубликован?">
      <bpmn:incoming>Flow_to_ShowPublish</bpmn:incoming>
      <bpmn:outgoing>Flow_160iz9a</bpmn:outgoing>
      <bpmn:outgoing>Flow_0sp9ed0</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_ValidateConditions" name="Проверить обязательные условия публикации">
      <bpmn:incoming>Flow_to_Validate</bpmn:incoming>
      <bpmn:outgoing>Flow_1u0ne0m</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_A2_ServiceError" name="Сообщение об ошибке сервиса">
      <bpmn:incoming>Flow_Publish_Error</bpmn:incoming>
      <bpmn:outgoing>Flow_0593yuc</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_0s9661u">
      <bpmn:incoming>Flow_0593yuc</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Activity_1earkek" name="Отобразить успех операции">
      <bpmn:incoming>Flow_1g98zh1</bpmn:incoming>
      <bpmn:outgoing>Flow_1wtunm2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Success" name="Товар опубликован на витрине">
      <bpmn:incoming>Flow_to_EndSuccess</bpmn:incoming>
      <bpmn:incoming>Flow_1wtunm2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Activity_0wuwlm4" name="Продавец дополняет карточку">
      <bpmn:incoming>Flow_133fw8i</bpmn:incoming>
      <bpmn:outgoing>Flow_1r181wj</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_07wnm8t" name="Подсветить, какие условия не выполнены">
      <bpmn:incoming>Flow_Conditions_No</bpmn:incoming>
      <bpmn:outgoing>Flow_133fw8i</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_to_OpenCard" sourceRef="Start_Task2" targetRef="Task_OpenCard" />
    <bpmn:sequenceFlow id="Flow_to_ShowPublish" sourceRef="Task_OpenCard" targetRef="Gateway_0d9badk" />
    <bpmn:sequenceFlow id="Flow_160iz9a" name="нет" sourceRef="Gateway_0d9badk" targetRef="Task_ShowPublishButton" />
    <bpmn:sequenceFlow id="Flow_to_ClickPublish" sourceRef="Task_ShowPublishButton" targetRef="Task_ClickPublish" />
    <bpmn:sequenceFlow id="Flow_0sp9ed0" name="да" sourceRef="Gateway_0d9badk" targetRef="Activity_0ttedc3" />
    <bpmn:sequenceFlow id="Flow_02jimq0" sourceRef="Gateway_02wmdhm" targetRef="Task_LogHistoryAndResult" />
    <bpmn:sequenceFlow id="Flow_to_EndSuccess" sourceRef="Task_LogHistoryAndResult" targetRef="End_Success" />
    <bpmn:sequenceFlow id="Flow_1r181wj" sourceRef="Activity_0wuwlm4" targetRef="Task_ClickPublish" />
    <bpmn:sequenceFlow id="Flow_to_Validate" sourceRef="Task_ClickPublish" targetRef="Task_ValidateConditions" />
    <bpmn:sequenceFlow id="Flow_1u0ne0m" sourceRef="Task_ValidateConditions" targetRef="Gateway_ConditionsOk" />
    <bpmn:sequenceFlow id="Flow_Conditions_No" name="Нет" sourceRef="Gateway_ConditionsOk" targetRef="Activity_07wnm8t" />
    <bpmn:sequenceFlow id="Flow_Conditions_Yes" name="Да" sourceRef="Gateway_ConditionsOk" targetRef="Task_PublishAndCatalog" />
    <bpmn:sequenceFlow id="Flow_0irkyr6" sourceRef="Task_PublishAndCatalog" targetRef="Gateway_PublishResult" />
    <bpmn:sequenceFlow id="Flow_Publish_Error" name="нет" sourceRef="Gateway_PublishResult" targetRef="Task_A2_ServiceError" />
    <bpmn:sequenceFlow id="Flow_Publish_Ok" name="Да" sourceRef="Gateway_PublishResult" targetRef="Gateway_02wmdhm" />
    <bpmn:sequenceFlow id="Flow_1g98zh1" sourceRef="Gateway_02wmdhm" targetRef="Activity_1earkek" />
    <bpmn:sequenceFlow id="Flow_0593yuc" sourceRef="Task_A2_ServiceError" targetRef="Event_0s9661u" />
    <bpmn:sequenceFlow id="Flow_1wtunm2" sourceRef="Activity_1earkek" targetRef="End_Success" />
    <bpmn:sequenceFlow id="Flow_133fw8i" sourceRef="Activity_07wnm8t" targetRef="Activity_0wuwlm4" />
  </bpmn:process>
